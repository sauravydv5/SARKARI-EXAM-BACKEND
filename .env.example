PORT=5000
NODE_ENV=production

# REQUIRED in production — min 32 random characters
JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_EXPIRE=7d

# REQUIRED in production — your MongoDB connection string
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/sarkari-result?retryWrites=true&w=majority

# REQUIRED in production — your live site URL(s), comma-separated
CORS_ORIGIN=https://yourdomain.com

# REQUIRED — strong password, not admin123
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=Use_A_Strong_Password_Here_123!

# Auto-import reference posts only when DB is empty (never deletes existing posts)
SEED_DEMO=false
SEED_ADMIN=true

TRUST_PROXY=true
